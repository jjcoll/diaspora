# Get your sandbox API key:
# curl https://public-api.sandbox.bunq.com/v1/sandbox-user-person \
#   -X POST -H "Content-Type: application/json" \
#   -H "Cache-Control: none" -H "User-Agent: diaspora-demo" \
#   -H "X-Bunq-Client-Request-Id: setup-001" \
#   -H "X-Bunq-Language: en_US" -H "X-Bunq-Region: nl_NL" \
#   -H "X-Bunq-Geolocation: 0 0 0 0 000" -d '{}'

BUNQ_API_KEY=sandbox_...

# Filled in automatically by bunq_setup.py
BUNQ_USER_ID=
BUNQ_ACCOUNT_ID=

DIDIT_ENABLED=false
DIDIT_API_KEY=<your_api_key>
DIDIT_WORKFLOW_ID=ea4ad523-f2e1-414c-a15e-c76dbb0ecb3c
DIDIT_API_URL=https://verification.didit.me
